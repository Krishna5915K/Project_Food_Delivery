const mongoose = require('mongoose');

const roleSchema = new mongoose.Schema({
    name: {
        type: String,
        required: true,
        unique: true,
        trim: true
    },
    permissions: [{
        type: String // List of permission names, e.g. ['read_users', 'write_restaurants']
    }]
}, { timestamps: true });

const Role = mongoose.model('Role', roleSchema);
module.exports = Role;
