<%- include('partials/admin-header') %>

<div style="margin-bottom: 2rem;">
  <p class="text-muted">Configure platform configurations, operations rules, and system details.</p>
</div>

<div class="glass-card" style="max-width: 650px; margin: 0 auto;">
  <form id="settings-form" style="display:flex; flex-direction:column; gap:1.5rem;">
    
    <% settings.forEach(s => { %>
      <div class="form-group">
        <label for="setting-<%= s.key %>" style="font-weight:700; color:white; display:block;">
          <%= s.key.split('_').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ') %>
        </label>
        <% if (s.description) { %>
          <span style="font-size:0.8rem; color:var(--text-secondary); display:block; margin-bottom:0.4rem;"><%= s.description %></span>
        <% } %>
        <input type="text" id="setting-<%= s.key %>" name="<%= s.key %>" class="form-input" value="<%= s.value %>" required>
      </div>
    <% }) %>

    <button type="submit" id="saveBtn" class="btn btn-primary" style="margin-top: 1rem;"><i class="fa-solid fa-floppy-disk"></i> Save Settings Configuration</button>
  </form>
</div>

<script>
  document.getElementById('settings-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('saveBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving Settings...';

    // Collect all settings
    const settingsObj = {};
    const inputs = document.querySelectorAll('#settings-form input');
    inputs.forEach(input => {
      settingsObj[input.name] = input.value.trim();
    });

    try {
      const res = await fetch('/api/v1/admin/settings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ settings: settingsObj })
      });
      const json = await res.json();
      if (json.success) {
        alert('Platform settings updated successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Failed to save settings.');
        btn.disabled = false;
        btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Settings Configuration';
      }
    } catch (err) {
      alert('Network error.');
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Save Settings Configuration';
    }
  });
</script>

<%- include('partials/admin-footer') %>
