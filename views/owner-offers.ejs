<%- include('partials/owner-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
  <div>
    <p class="text-muted">Create restaurant-specific discount coupons to attract customers.</p>
  </div>
  <button class="btn btn-primary" onclick="openCreateModal()"><i class="fa-solid fa-plus"></i> Create Coupon</button>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr>
        <th>Code</th>
        <th>Type</th>
        <th>Value</th>
        <th>Min Order Value</th>
        <th>Usage Limit</th>
        <th>Expiry Date</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (coupons && coupons.length > 0) { %>
        <% coupons.forEach(c => { %>
          <tr>
            <td><code><%= c.code %></code></td>
            <td style="text-transform:capitalize;"><%= c.discountType %></td>
            <td><%= c.discountType === 'percentage' ? c.discountValue + '%' : '₹' + c.discountValue %></td>
            <td>₹<%= c.minOrderValue %></td>
            <td><%= c.usedCount %> / <%= c.usageLimit %></td>
            <td><%= new Date(c.expiresAt).toLocaleDateString() %></td>
            <td>
              <span class="badge <%= c.isActive ? 'badge-success' : 'badge-danger' %>">
                <%= c.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td>
              <div style="display:flex; gap:0.5rem;">
                <button class="btn btn-secondary btn-sm" onclick="openEditModal('<%= c._id %>')"><i class="fa-solid fa-pen"></i> Edit</button>
                <button class="btn btn-secondary btn-sm" onclick="deleteOffer('<%= c._id %>')" style="color:var(--danger-color);"><i class="fa-solid fa-trash"></i> Delete</button>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="8" style="text-align:center; color:var(--text-secondary);">No offers created for your restaurant yet.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<!-- Add Offer Modal -->
<div id="offerModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Create Coupon</h3>
      <button onclick="closeCreateModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="create-offer-form" style="display:flex; flex-direction:column; gap:1rem;">
      <div class="form-group">
        <label for="code">Coupon Code (Uppercase)</label>
        <input type="text" id="code" class="form-input" required placeholder="SAVE50" style="text-transform:uppercase;">
      </div>
      <div class="form-group">
        <label for="discountType">Discount Type</label>
        <select id="discountType" class="form-select" required>
          <option value="flat">Flat Value Discount (₹)</option>
          <option value="percentage">Percentage Discount (%)</option>
        </select>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div class="form-group">
          <label for="discountValue">Discount Value</label>
          <input type="number" id="discountValue" class="form-input" required min="1" placeholder="50">
        </div>
        <div class="form-group">
          <label for="minOrderValue">Min. Order Value (₹)</label>
          <input type="number" id="minOrderValue" class="form-input" required min="0" value="0">
        </div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div class="form-group">
          <label for="maxDiscountValue">Max Discount Limit (₹)</label>
          <input type="number" id="maxDiscountValue" class="form-input" min="0" value="0" placeholder="For percentages">
        </div>
        <div class="form-group">
          <label for="usageLimit">Total Usage Limit</label>
          <input type="number" id="usageLimit" class="form-input" required min="1" value="100">
        </div>
      </div>
      <div class="form-group">
        <label for="expiresAt">Expiration Date</label>
        <input type="date" id="expiresAt" class="form-input" required>
      </div>
      <div class="form-group" style="display:flex; gap:0.5rem; align-items:center;">
        <input type="checkbox" id="isActive" checked style="width:auto; margin:0;">
        <label for="isActive" style="margin:0; cursor:pointer;">Coupon is Active</label>
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary" style="margin-top:1rem;">Create Coupon</button>
    </form>
  </div>
</div>

<!-- Edit Offer Modal -->
<div id="editOfferModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Edit Coupon</h3>
      <button onclick="closeEditModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="edit-offer-form" style="display:flex; flex-direction:column; gap:1rem;">
      <input type="hidden" id="edit-id">
      <div class="form-group">
        <label for="edit-code">Coupon Code (Uppercase)</label>
        <input type="text" id="edit-code" class="form-input" required placeholder="SAVE50" style="text-transform:uppercase;">
      </div>
      <div class="form-group">
        <label for="edit-discountType">Discount Type</label>
        <select id="edit-discountType" class="form-select" required>
          <option value="flat">Flat Value Discount (₹)</option>
          <option value="percentage">Percentage Discount (%)</option>
        </select>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div class="form-group">
          <label for="edit-discountValue">Discount Value</label>
          <input type="number" id="edit-discountValue" class="form-input" required min="1">
        </div>
        <div class="form-group">
          <label for="edit-minOrderValue">Min. Order Value (₹)</label>
          <input type="number" id="edit-minOrderValue" class="form-input" required min="0">
        </div>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
        <div class="form-group">
          <label for="edit-maxDiscountValue">Max Discount Limit (₹)</label>
          <input type="number" id="edit-maxDiscountValue" class="form-input" min="0">
        </div>
        <div class="form-group">
          <label for="edit-usageLimit">Total Usage Limit</label>
          <input type="number" id="edit-usageLimit" class="form-input" required min="1">
        </div>
      </div>
      <div class="form-group">
        <label for="edit-expiresAt">Expiration Date</label>
        <input type="date" id="edit-expiresAt" class="form-input" required>
      </div>
      <div class="form-group" style="display:flex; gap:0.5rem; align-items:center;">
        <input type="checkbox" id="edit-isActive" style="width:auto; margin:0;">
        <label for="edit-isActive" style="margin:0; cursor:pointer;">Coupon is Active</label>
      </div>

      <button type="submit" id="editSubmitBtn" class="btn btn-primary" style="margin-top:1rem;">Save Coupon</button>
    </form>
  </div>
</div>

<script>
  const coupons = <%- JSON.stringify(coupons) %>;

  function openCreateModal() {
    document.getElementById('offerModal').style.display = 'flex';
  }
  function closeCreateModal() {
    document.getElementById('offerModal').style.display = 'none';
  }

  function openEditModal(couponId) {
    const c = coupons.find(item => item._id === couponId);
    if (!c) return;

    document.getElementById('edit-id').value = c._id;
    document.getElementById('edit-code').value = c.code;
    document.getElementById('edit-discountType').value = c.discountType;
    document.getElementById('edit-discountValue').value = c.discountValue;
    document.getElementById('edit-minOrderValue').value = c.minOrderValue;
    document.getElementById('edit-maxDiscountValue').value = c.maxDiscountValue || 0;
    document.getElementById('edit-usageLimit').value = c.usageLimit || 1;
    document.getElementById('edit-isActive').checked = c.isActive;

    const expiryDate = new Date(c.expiresAt).toISOString().split('T')[0];
    document.getElementById('edit-expiresAt').value = expiryDate;

    document.getElementById('editOfferModal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('editOfferModal').style.display = 'none';
  }

  document.getElementById('create-offer-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;

    const payload = {
      code: document.getElementById('code').value.toUpperCase().trim(),
      discountType: document.getElementById('discountType').value,
      discountValue: document.getElementById('discountValue').value,
      minOrderValue: document.getElementById('minOrderValue').value,
      maxDiscountValue: document.getElementById('maxDiscountValue').value,
      usageLimit: document.getElementById('usageLimit').value,
      expiresAt: document.getElementById('expiresAt').value,
      isActive: document.getElementById('isActive').checked
    };

    try {
      const res = await fetch('/api/v1/owner/offers', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Coupon created successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Error creating coupon.');
        btn.disabled = false;
      }
    } catch (err) {
      alert('Network error.');
      btn.disabled = false;
    }
  });

  document.getElementById('edit-offer-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('editSubmitBtn');
    btn.disabled = true;

    const id = document.getElementById('edit-id').value;
    const payload = {
      code: document.getElementById('edit-code').value.toUpperCase().trim(),
      discountType: document.getElementById('edit-discountType').value,
      discountValue: document.getElementById('edit-discountValue').value,
      minOrderValue: document.getElementById('edit-minOrderValue').value,
      maxDiscountValue: document.getElementById('edit-maxDiscountValue').value,
      usageLimit: document.getElementById('edit-usageLimit').value,
      expiresAt: document.getElementById('edit-expiresAt').value,
      isActive: document.getElementById('edit-isActive').checked
    };

    try {
      const res = await fetch(`/api/v1/owner/offers/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Coupon updated successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Error updating coupon.');
        btn.disabled = false;
      }
    } catch (err) {
      alert('Network error.');
      btn.disabled = false;
    }
  });

  async function deleteOffer(id) {
    if (!confirm('Are you sure you want to delete this coupon?')) return;
    try {
      const res = await fetch(`/api/v1/owner/offers/${id}`, {
        method: 'DELETE'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert(json.message || 'Error deleting coupon.');
      }
    } catch (err) {
      alert('Network error.');
    }
  }
</script>

<%- include('partials/owner-footer') %>
