<%- include('partials/header') %>

<div style="margin-bottom: 2.5rem;">
  <h2 style="font-weight: 800; font-size: 2rem;">My Profile</h2>
  <p class="text-muted">Manage your personal settings, password verification, and address registry.</p>
</div>

<div class="grid-2">
  <div class="glass-card" style="display:flex; flex-direction:column; gap:1.5rem;">
    <div style="display:flex; align-items:center; gap:1.5rem;">
      <img src="<%= user.profileImage || 'https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=150' %>" style="width:80px; height:80px; object-fit:cover; border-radius:50%; border:2px solid var(--accent-color);" alt="profile">
      <div>
        <h3 style="font-size:1.4rem; font-weight:800; color:white;"><%= user.name %></h3>
        <p class="text-muted" style="text-transform:uppercase; font-size:0.75rem; font-weight:700;"><i class="fa-solid fa-user-tag" style="color:var(--accent-color);"></i> <%= user.role %></p>
      </div>
    </div>

    <div style="display:flex; flex-direction:column; gap:1rem; border-top:1px solid var(--border-color); padding-top:1.5rem;">
      <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--border-color); padding-bottom:0.75rem;">
        <span class="text-muted">Email Address</span>
        <strong style="color:white;"><%= user.email %></strong>
      </div>
      <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--border-color); padding-bottom:0.75rem;">
        <span class="text-muted">Phone Number</span>
        <strong style="color:white;"><%= user.phone || 'Not provided' %></strong>
      </div>
      <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--border-color); padding-bottom:0.75rem;">
        <span class="text-muted">Email Verification status</span>
        <span>
          <% if (user.isEmailVerified) { %>
            <span style="color:#10b981; font-weight:700;"><i class="fa-solid fa-circle-check"></i> Verified</span>
          <% } else { %>
            <span style="color:#ef4444; font-weight:700;"><i class="fa-solid fa-circle-exclamation"></i> Unverified</span>
          <% } %>
        </span>
      </div>
      <div style="display:flex; justify-content:space-between; padding-bottom:0.75rem;">
        <span class="text-muted">Member Since</span>
        <strong style="color:white;"><%= new Date(user.createdAt).toLocaleDateString() %></strong>
      </div>
    </div>

    <div style="display:flex; gap:1rem;">
      <a href="/profile/edit" class="btn btn-primary" style="flex:1;"><i class="fa-solid fa-user-pen"></i> Edit Profile</a>
      <a href="/addresses" class="btn btn-secondary" style="flex:1;"><i class="fa-solid fa-map-location-dot"></i> Manage Addresses</a>
    </div>
  </div>

  <div>
    <div class="glass-card" style="text-align:center; padding:2rem; display:flex; flex-direction:column; gap:1rem;">
      <h3 style="font-size:1.25rem; font-weight:800; text-align:left;"><i class="fa-solid fa-wallet" style="color:var(--accent-color);"></i> Wallet Balance</h3>
      <div style="background:rgba(255,255,255,0.02); padding:1.5rem; border-radius:14px; border:1px solid var(--border-color); text-align:center;">
        <span class="text-muted" style="font-size:0.85rem; display:block; margin-bottom:0.5rem;">Preloaded Credits</span>
        <h2 style="font-size:2.25rem; font-weight:800; color:white;">₹1,500.00</h2>
      </div>
      <p class="text-muted" style="font-size:0.8rem; text-align:left;">Use your wallet balance at checkout for instant order processing without cards.</p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
