<%- include('partials/owner-header') %>

<div style="margin-bottom: 2rem;">
  <p class="text-muted">Real-time oversight of delivery partners status and active dispatch runs for your restaurant.</p>
</div>

<div style="display:grid; grid-template-columns: 2fr 1fr; gap:1.5rem; align-items: flex-start;">
  <!-- Left Side: Active Runs -->
  <div>
    <h3 style="font-size:1.25rem; font-weight:800; color:white; margin-bottom:1rem;"><i class="fa-solid fa-truck-fast" style="color:var(--accent-color);"></i> Active Dispatches</h3>
    <div style="display:flex; flex-direction:column; gap:1rem;">
      <% if (activeRuns && activeRuns.length > 0) { %>
        <% activeRuns.forEach(run => { %>
          <div class="glass-card" style="padding:1.25rem; border-color: rgba(255, 255, 255, 0.08);">
            <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border-color); padding-bottom:0.5rem; margin-bottom:0.75rem;">
              <strong style="color:white;">Order #<%= run._id.toString().slice(-6).toUpperCase() %></strong>
              <span class="badge <%= run.deliveryBoyStatus === 'accepted' ? 'badge-success' : 'badge-warning' %>">
                Rider: <%= run.deliveryBoyStatus.toUpperCase() %>
              </span>
            </div>
            <div style="font-size:0.9rem; display:flex; flex-direction:column; gap:0.4rem;" class="text-muted">
              <div><i class="fa-solid fa-circle-user"></i> Customer: <strong style="color:white;"><%= run.user ? run.user.name : 'Guest' %></strong></div>
              <div><i class="fa-solid fa-motorcycle"></i> Assigned Rider: <strong style="color:white;"><%= run.deliveryBoy ? run.deliveryBoy.name : 'None' %></strong> (<%= run.deliveryBoy ? run.deliveryBoy.phone || 'No phone' : 'N/A' %>)</div>
              <div><i class="fa-solid fa-location-dot"></i> Drop Address: <span style="color:white;"><%= run.deliveryAddress %></span></div>
              <div><i class="fa-solid fa-clock"></i> Status: <strong style="color:var(--accent-color); text-transform:uppercase;"><%= run.orderStatus.replace('_', ' ') %></strong></div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <div class="glass-card" style="text-align:center; padding:3rem; border-color: rgba(255, 255, 255, 0.08);">
          <i class="fa-solid fa-clipboard-list" style="font-size:2.5rem; color:var(--text-secondary); margin-bottom:1rem;"></i>
          <p class="text-muted">No active delivery runs at the moment.</p>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Right Side: Riders Status -->
  <div>
    <h3 style="font-size:1.25rem; font-weight:800; color:white; margin-bottom:1rem;"><i class="fa-solid fa-users" style="color:var(--accent-color);"></i> Delivery Partners</h3>
    <div class="glass-card" style="padding:1rem; display:flex; flex-direction:column; gap:0.75rem; border-color: rgba(255, 255, 255, 0.08);">
      <% if (riders && riders.length > 0) { %>
        <% riders.forEach(r => { %>
          <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid rgba(255,255,255,0.05); padding-bottom:0.5rem;">
            <div>
              <strong style="color:white; font-size:0.9rem; display:block;"><%= r.name %></strong>
              <span class="text-muted" style="font-size:0.75rem;"><%= r.phone || 'No Phone' %></span>
            </div>
            <div>
              <span class="badge <%= r.status === 'active' ? 'badge-success' : 'badge-danger' %>" style="text-transform:uppercase; font-size:0.7rem; padding:0.2rem 0.4rem;">
                <%= r.status %>
              </span>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted" style="text-align:center; font-size:0.85rem; padding:1rem 0;">No riders registered on the platform.</p>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/owner-footer') %>
