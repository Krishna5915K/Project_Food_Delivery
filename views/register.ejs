<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - FoodClone</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <main style="display:flex;align-items:center;justify-content:center;height:100vh;padding:1rem;">
    <div class="glass-card" style="max-width:520px;width:100%;padding:2rem;">
      <h2 style="margin-bottom:0.25rem;">Create Account</h2>
      <p class="text-muted" style="margin-bottom:1rem;">Register to order food, manage restaurants, or accept deliveries.</p>

      <div id="alert" class="auth-alert-message" style="display:none;margin-bottom:0.75rem;"></div>

      <form id="register-form">
        <div class="form-group">
          <label for="name">Full name</label>
          <input id="name" type="text" class="form-input" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" type="email" class="form-input" required>
        </div>
        <div class="form-group">
          <label for="phone">Phone (E.164)</label>
          <input id="phone" type="tel" class="form-input" placeholder="+919876543210" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="password-wrapper">
            <input id="password" type="password" class="form-input" required>
            <button type="button" class="password-toggle-btn" onclick="togglePassword()"><i class="fa-solid fa-eye"></i></button>
          </div>
        </div>
        <div class="form-group">
          <label for="role">Account Role</label>
          <select id="role" class="form-input">
            <option value="customer" selected>Customer</option>
            <option value="restaurant_owner">Restaurant Owner</option>
            <option value="delivery_boy">Delivery Partner</option>
          </select>
        </div>

        <button id="submitBtn" class="btn btn-primary w-100" type="submit">Create Account</button>
      </form>

      <div style="margin-top:1rem;display:flex;justify-content:space-between;align-items:center;font-size:0.9rem;">
        <a href="/login">Already have an account? Sign in</a>
      </div>
    </div>
  </main>

  <script>
    function togglePassword() {
      const p = document.getElementById('password');
      p.type = p.type === 'password' ? 'text' : 'password';
    }

    document.getElementById('register-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const password = document.getElementById('password').value;
      const role = document.getElementById('role').value;

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';

      // Basic client-side validation
      const phoneRegex = /^\+?[1-9]\d{1,14}$/;
      if (!phoneRegex.test(phone)) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Phone must be in E.164 format (e.g. +919876543210).';
        alertDiv.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = 'Create Account';
        return;
      }

      try {
        const res = await fetch('/api/v1/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, password, role })
        });
        const json = await res.json();
        if (json.success) {
          window.location.href = '/login';
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Registration failed';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Create Account';
      }
    });
  </script>
</body>
</html>
