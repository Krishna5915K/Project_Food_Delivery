<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> - Food Platform
  </title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
  <main>
    <div class="glass-card">
      <div style="margin-bottom: 1.5rem;">
        <i class="fa-solid fa-user-plus"
          style="color:var(--accent-color); font-size:2.5rem; margin-bottom: 0.5rem;"></i>
        <h2>Create Account</h2>
        <p class="text-muted">Join Food Platform to order delicious food instantly.</p>
      </div>

      <div id="alert" class="auth-alert-message"></div>

      <form id="register-form">
        <div class="form-group">
          <label for="name">Full Name</label>
          <input id="name" type="text" class="form-input" placeholder="John Doe" required>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input id="email" type="email" class="form-input" placeholder="john@example.com" required>
        </div>
        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input id="phone" type="tel" class="form-input" placeholder="+919876543210" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" type="password" class="form-input" placeholder="Min. 6 characters" minlength="6"
            required>
        </div>

        <button id="submitBtn" class="btn btn-primary" type="submit">Sign Up</button>
      </form>

      <div class="auth-links" style="justify-content: center; gap: 0.5rem;">
        <span style="color: var(--text-secondary);">Already have an account?</span>
        <a href="/login" style="font-weight: 700;">Sign In</a>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('register-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const phone = document.getElementById('phone').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('submitBtn');

      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating account...';

      try {
        const res = await fetch('/api/v1/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, phone, password })
        });
        const json = await res.json();
        if (json.success) {
          alertDiv.className = 'auth-alert-message success';
          alertDiv.innerText = json.message || 'Registration Successful.';
          alertDiv.style.display = 'block';
          document.getElementById('register-form').reset();
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Registration failed.';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Sign Up';
      }
    });
  </script>
</body>

</html>