<%- include('partials/admin-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
  <div>
    <p class="text-muted">Manage global food categories (e.g. Desserts, Pizzas, Burgers) and associate them to kitchens.</p>
  </div>
  <button class="btn btn-primary" onclick="openModal()"><i class="fa-solid fa-folder-plus"></i> Create Category</button>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr>
        <th>Category Name</th>
        <th>Associated Restaurant</th>
        <th>Description</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% categories.forEach(cat => { %>
        <tr>
          <td><strong><%= cat.name %></strong></td>
          <td><%= cat.restaurant ? cat.restaurant.name : 'All' %></td>
          <td><%= cat.description || 'N/A' %></td>
          <td>
            <span class="badge <%= cat.isActive ? 'badge-success' : 'badge-danger' %>">
              <%= cat.isActive ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td>
            <button class="btn btn-secondary btn-sm" onclick="deleteCategory('<%= cat._id %>')" style="color:var(--danger-color);"><i class="fa-solid fa-trash-can"></i> Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Add Category Modal -->
<div id="catModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Create Category</h3>
      <button onclick="closeModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="create-cat-form" style="display:flex; flex-direction:column; gap:1rem;">
      <div class="form-group">
        <label for="name">Category Name</label>
        <input type="text" id="name" class="form-input" required placeholder="e.g. Burgers, Mocktails...">
      </div>
      <div class="form-group">
        <label for="restaurant">Associate Restaurant</label>
        <select id="restaurant" class="form-select" required>
          <option value="">Select Restaurant</option>
          <% restaurants.forEach(r => { %>
            <option value="<%= r._id %>"><%= r.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="description">Description</label>
        <input type="text" id="description" class="form-input" placeholder="Quick description...">
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary" style="margin-top:1rem;">Save Category</button>
    </form>
  </div>
</div>

<script>
  function openModal() {
    document.getElementById('catModal').style.display = 'flex';
  }
  function closeModal() {
    document.getElementById('catModal').style.display = 'none';
  }

  async function deleteCategory(id) {
    if (!confirm('Are you sure you want to delete this category?')) return;
    try {
      const res = await fetch(`/api/v1/categories/${id}`, {
        method: 'DELETE'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      }
    } catch (err) {
      alert('Error.');
    }
  }

  document.getElementById('create-cat-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;

    const payload = {
      name: document.getElementById('name').value.trim(),
      restaurant: document.getElementById('restaurant').value,
      description: document.getElementById('description').value.trim()
    };

    try {
      const res = await fetch('/api/v1/categories', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Category added successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Failed to save.');
        btn.disabled = false;
      }
    } catch (err) {
      alert('Error.');
      btn.disabled = false;
    }
  });
</script>

<%- include('partials/admin-footer') %>
