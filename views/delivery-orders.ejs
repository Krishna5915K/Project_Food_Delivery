<%- include('partials/delivery-header') %>

<div style="margin-bottom: 2rem;">
  <h2 style="font-weight: 800; font-size: 1.75rem;">Delivery History</h2>
  <p class="text-muted">Review your successfully completed deliveries.</p>
</div>

<div style="display:flex; flex-direction:column; gap:1rem;">
  <% if (orders && orders.length > 0) { %>
    <% orders.forEach(o => { %>
      <div class="order-card" style="border-left: 4px solid var(--accent-color);">
        <div class="order-title">
          <span>Order #<%= o._id.toString().slice(-6).toUpperCase() %></span>
          <span style="font-weight:700; color:var(--accent-color);">₹<%= o.totalAmount %></span>
        </div>
        
        <div style="font-size:0.9rem; color:var(--text-secondary); display:flex; flex-direction:column; gap:0.5rem; margin:0.25rem 0;">
          <div><i class="fa-solid fa-store"></i> Restaurant: <strong style="color:white;"><%= o.restaurant ? o.restaurant.name : 'Unknown' %></strong></div>
          <div><i class="fa-solid fa-location-dot"></i> Dropped Address: <span style="color:white;"><%= o.deliveryAddress %></span></div>
          <div><i class="fa-solid fa-calendar-check"></i> Date: <span style="color:white;"><%= new Date(o.updatedAt).toLocaleString() %></span></div>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border-color); padding-top:0.75rem; margin-top:0.5rem; font-size:0.85rem;">
          <span style="background:rgba(16,185,129,0.15); color:var(--accent-color); padding:0.25rem 0.5rem; border-radius:6px; border:1px solid rgba(16,185,129,0.3); font-weight:800; font-size:0.75rem;">
            <i class="fa-solid fa-check"></i> DELIVERED
          </span>
          <span style="color:var(--text-secondary);">Fee: ₹40.00</span>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="glass-card" style="text-align:center; padding:3rem;">
      <i class="fa-solid fa-clock-rotate-left" style="font-size:3rem; color:var(--text-secondary); margin-bottom:1rem;"></i>
      <h3>No History Found</h3>
      <p class="text-muted" style="margin-top:0.5rem;">You haven't completed any runs yet. Start accepting orders to build your record!</p>
    </div>
  <% } %>
</div>

<%- include('partials/delivery-footer') %>
