<%- include('partials/header') %>

<div style="text-align:center; padding: 4rem 1rem;">
  <i class="fa-solid fa-circle-check" style="color:var(--success-color); font-size:5rem; margin-bottom: 1.5rem;"></i>
  <h2 style="font-size:2.5rem; font-weight:800; margin-bottom:0.5rem;">Order Placed Successfully! 🎉</h2>
  <p class="text-muted" style="font-size:1.1rem; max-width:550px; margin: 0 auto 2.5rem;">Thank you for ordering with FoodClone. Your order is being prepared and will be delivered shortly.</p>

  <div class="glass-card" style="max-width:500px; margin: 0 auto 2.5rem; text-align:left; padding:2rem;">
    <h3 style="font-size:1.2rem; font-weight:800; margin-bottom:1rem; border-bottom:1px solid var(--border-color); padding-bottom:0.5rem;">Order Summary</h3>
    
    <div style="display:flex; flex-direction:column; gap:0.75rem; font-size:0.95rem;">
      <div style="display:flex; justify-content:space-between;">
        <span class="text-muted">Order ID</span>
        <strong style="color:white;"><%= order._id %></strong>
      </div>
      <div style="display:flex; justify-content:space-between;">
        <span class="text-muted">Restaurant</span>
        <span style="color:white; font-weight:600;"><%= order.restaurant.name %></span>
      </div>
      <div style="display:flex; justify-content:space-between;">
        <span class="text-muted">Amount Paid</span>
        <strong class="price">₹<%= order.totalAmount %></strong>
      </div>
      <div style="display:flex; justify-content:space-between;">
        <span class="text-muted">Payment Method</span>
        <span style="text-transform:uppercase; color:white;"><%= order.paymentMethod %></span>
      </div>
      <div style="display:flex; flex-direction:column; gap:0.25rem;">
        <span class="text-muted">Delivery Address</span>
        <span style="color:white; font-size:0.875rem;"><%= order.deliveryAddress %></span>
      </div>
    </div>
  </div>

  <div style="display:flex; justify-content:center; gap:1rem;">
    <a href="/orders/history" class="btn btn-primary" style="width:auto;"><i class="fa-solid fa-clock-rotate-left"></i> View Order History</a>
    <a href="/restaurants" class="btn btn-secondary" style="width:auto;"><i class="fa-solid fa-basket-shopping"></i> Continue Shopping</a>
  </div>
</div>

<%- include('partials/footer') %>
