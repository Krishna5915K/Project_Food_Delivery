<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - FoodClone</title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <main>
    <div class="glass-card">
      <div style="margin-bottom: 1.5rem;">
        <i class="fa-solid fa-key" style="color:var(--accent-color); font-size:2.5rem; margin-bottom: 0.5rem;"></i>
        <h2>Forgot Password</h2>
        <p class="text-muted">Enter your email address and we'll send you a password reset link.</p>
      </div>

      <div id="alert" class="auth-alert-message"></div>

      <form id="forgot-form">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input id="email" type="email" class="form-input" placeholder="name@example.com" required>
        </div>

        <button id="submitBtn" class="btn btn-primary" type="submit">Send Reset Link</button>
      </form>

      <div class="auth-links" style="justify-content: center; gap: 0.5rem;">
        <span style="color: var(--text-secondary);">Remember your password?</span>
        <a href="/login" style="font-weight: 700;">Sign In</a>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('forgot-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const email = document.getElementById('email').value.trim();
      const btn = document.getElementById('submitBtn');

      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';

      try {
        const res = await fetch('/api/v1/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });
        const json = await res.json();
        if (json.success) {
          alertDiv.className = 'auth-alert-message success';
          alertDiv.innerText = json.message || 'Password reset link sent to your email.';
          alertDiv.style.display = 'block';
          document.getElementById('forgot-form').reset();
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Failed to request password reset.';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Send Reset Link';
      }
    });
  </script>
</body>
</html>
