<%- include('partials/owner-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
  <div>
    <p class="text-muted">Manage your restaurant catalog. Add new items, update prices, or hide items currently out of stock.</p>
  </div>
  <button class="btn btn-primary" onclick="openModal()"><i class="fa-solid fa-circle-plus"></i> Add Menu Item</button>
</div>

<div class="menu-grid">
  <% if (foods && foods.length > 0) { %>
    <% foods.forEach(food => { %>
      <div class="food-card">
        <% if (food.image) { %>
          <img src="<%= food.image %>" class="food-img" alt="">
        <% } %>
        <div>
          <div style="display:flex; justify-content:space-between; align-items:center;">
            <strong style="color:white; font-size:1.1rem;"><%= food.name %></strong>
            <% if (food.isVeg) { %>
              <span style="color:#10b981; font-size:0.85rem;"><i class="fa-solid fa-leaf"></i></span>
            <% } else { %>
              <span style="color:#ef4444; font-size:0.85rem;"><i class="fa-solid fa-circle"></i></span>
            <% } %>
          </div>
          <span style="font-size:0.8rem; color:var(--text-secondary); display:block; margin:0.25rem 0;"><%= food.category ? food.category.name : 'Uncategorized' %></span>
          <p class="text-muted" style="font-size:0.8rem; height:40px; overflow:hidden; text-overflow:ellipsis;"><%= food.description %></p>
        </div>

        <div style="display:flex; justify-content:space-between; align-items:center; border-top:1px solid var(--border-color); padding-top:0.75rem;">
          <strong class="price">₹<%= food.price %></strong>
          
          <div style="display:flex; gap:0.5rem;">
            <button class="btn btn-secondary btn-sm" onclick="deleteItem('<%= food._id %>')" style="color:var(--danger-color); padding: 0.3rem 0.5rem;"><i class="fa-solid fa-trash-can"></i></button>
          </div>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div style="grid-column: 1/-1; text-align:center; padding:3rem;" class="glass-card">
      <i class="fa-solid fa-bowl-food" style="font-size:3rem; color:var(--text-secondary); margin-bottom:1rem;"></i>
      <h3>No Menu Items</h3>
      <p class="text-muted">You haven't listed any dishes yet. Click "Add Menu Item" to start.</p>
    </div>
  <% } %>
</div>

<!-- Add Menu Item Modal -->
<div id="menuModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Add Menu Item</h3>
      <button onclick="closeModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="create-menu-form" style="display:flex; flex-direction:column; gap:1rem;" enctype="multipart/form-data">
      <div class="form-group">
        <label for="foodName">Item Name</label>
        <input type="text" id="foodName" class="form-input" required placeholder="e.g. Cheese Burger...">
      </div>
      <div class="form-group">
        <label for="foodDesc">Description</label>
        <input type="text" id="foodDesc" class="form-input" placeholder="Fresh cheddar cheese, lettuce, tomato...">
      </div>
      <div class="form-group">
        <label for="foodPrice">Price (₹)</label>
        <input type="number" id="foodPrice" class="form-input" required placeholder="e.g. 199">
      </div>
      <div class="form-group">
        <label for="foodCategory">Category</label>
        <select id="foodCategory" class="form-select" required>
          <option value="">Select Category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat._id %>"><%= cat.name %></option>
          <% }) %>
        </select>
      </div>

      <div style="display:flex; gap:2rem;">
        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
          <input type="checkbox" id="isVeg" checked style="width:16px; height:16px;">
          <span>Vegetarian</span>
        </label>
      </div>

      <div class="form-group">
        <label for="foodImage">Item Image</label>
        <input type="file" id="foodImage" name="foodImage" accept="image/*" class="form-input">
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary" style="margin-top:1rem;">Add dish to menu</button>
    </form>
  </div>
</div>

<script>
  function openModal() {
    document.getElementById('menuModal').style.display = 'flex';
  }
  function closeModal() {
    document.getElementById('menuModal').style.display = 'none';
  }

  async function deleteItem(id) {
    if (!confirm('Are you sure you want to delete this menu item?')) return;
    try {
      const res = await fetch(`/api/v1/owner/menu/${id}`, {
        method: 'DELETE'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      }
    } catch (err) {
      alert('Error.');
    }
  }

  document.getElementById('create-menu-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;

    const formData = new FormData();
    formData.append('name', document.getElementById('foodName').value.trim());
    formData.append('description', document.getElementById('foodDesc').value.trim());
    formData.append('price', document.getElementById('foodPrice').value);
    formData.append('category', document.getElementById('foodCategory').value);
    formData.append('isVeg', document.getElementById('isVeg').checked);
    
    const fileInput = document.getElementById('foodImage');
    if (fileInput.files.length > 0) {
      formData.append('foodImage', fileInput.files[0]);
    }

    try {
      const res = await fetch('/api/v1/owner/menu', {
        method: 'POST',
        body: formData
      });
      const json = await res.json();
      if (json.success) {
        alert('Menu item added successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Error saving dish.');
        btn.disabled = false;
      }
    } catch (err) {
      alert('Server error.');
      btn.disabled = false;
    }
  });
</script>

<%- include('partials/owner-footer') %>
