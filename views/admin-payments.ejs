<%- include('partials/admin-header') %>

<div style="margin-bottom: 2rem;">
  <p class="text-muted">Review checkout transaction logs, payment methods, gateway responses, and audit records.</p>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr>
        <th>Transaction ID</th>
        <th>Customer</th>
        <th>Order Ref</th>
        <th>Method</th>
        <th>Amount</th>
        <th>Date</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% payments.forEach(p => { %>
        <tr>
          <td><code><%= p.transactionId %></code></td>
          <td><strong><%= p.user ? p.user.name : 'Guest' %></strong><br><span style="font-size:0.75rem; color:var(--text-secondary);"><%= p.user ? p.user.email : '' %></span></td>
          <td><code>#<%= p.order ? p.order._id.toString().slice(-6).toUpperCase() : 'N/A' %></code></td>
          <td style="text-transform:uppercase;"><%= p.paymentMethod %></td>
          <td style="font-weight:700; color:var(--success-color);">₹<%= p.amount %></td>
          <td style="font-size:0.85rem;"><%= new Date(p.createdAt).toLocaleDateString() %></td>
          <td>
            <span class="badge <%= p.status === 'completed' ? 'badge-success' : 'badge-danger' %>"><%= p.status %></span>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/admin-footer') %>
