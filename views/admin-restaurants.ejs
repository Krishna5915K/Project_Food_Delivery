<%- include('partials/admin-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
  <div>
    <p class="text-muted">Register new partner kitchens or audit approvals and menu statuses.</p>
  </div>
  <button class="btn btn-primary" onclick="openModal()"><i class="fa-solid fa-store"></i> Register Restaurant</button>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr>
        <th>Restaurant Name</th>
        <th>Owner Account</th>
        <th>Address</th>
        <th>Cuisines</th>
        <th>Approval</th>
        <th>Toggle Approval</th>
      </tr>
    </thead>
    <tbody>
      <% restaurants.forEach(r => { %>
        <tr>
          <td><strong><%= r.name %></strong></td>
          <td><%= r.owner ? r.owner.name : 'Unassigned' %></td>
          <td style="font-size:0.85rem; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= r.address %></td>
          <td>
            <% if(r.cuisineType) { %>
              <%= r.cuisineType.join(', ') %>
            <% } %>
          </td>
          <td>
            <span class="badge <%= r.isApproved ? 'badge-success' : 'badge-danger' %>">
              <%= r.isApproved ? 'Approved' : 'Pending' %>
            </span>
          </td>
          <td>
            <% if (r.isApproved) { %>
              <button class="btn btn-secondary btn-sm" onclick="toggleApproval('<%= r._id %>', false)" style="color:var(--danger-color);"><i class="fa-solid fa-circle-xmark"></i> Disapprove</button>
            <% } else { %>
              <button class="btn btn-secondary btn-sm" onclick="toggleApproval('<%= r._id %>', true)" style="color:var(--success-color);"><i class="fa-solid fa-circle-check"></i> Approve</button>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Add Restaurant Modal -->
<div id="restModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Register Restaurant</h3>
      <button onclick="closeModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="create-rest-form" style="display:flex; flex-direction:column; gap:1rem;">
      <div class="form-group">
        <label for="name">Restaurant Name</label>
        <input type="text" id="name" class="form-input" required placeholder="McDonalds, Pizza Hut...">
      </div>
      <div class="form-group">
        <label for="owner">Assign Owner Account</label>
        <select id="owner" class="form-select" required>
          <option value="">Select Owner Account</option>
          <% owners.forEach(o => { %>
            <option value="<%= o._id %>"><%= o.name %> (<%= o.email %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="cuisineType">Cuisines (Comma-separated)</label>
        <input type="text" id="cuisineType" class="form-input" placeholder="Italian, American, Pizza...">
      </div>
      <div class="form-group">
        <label for="address">Full Location Address</label>
        <input type="text" id="address" class="form-input" required placeholder="MG Road, Bangalore...">
      </div>
      <div style="display:grid; grid-template-columns: 1fr 1fr; gap:1rem;">
        <div class="form-group">
          <label for="deliveryTimeMinutes">Delivery Time (mins)</label>
          <input type="number" id="deliveryTimeMinutes" class="form-input" value="30" required>
        </div>
        <div class="form-group">
          <label for="minOrderAmount">Min. Order Value (₹)</label>
          <input type="number" id="minOrderAmount" class="form-input" value="100" required>
        </div>
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary" style="margin-top:1rem;">Save Restaurant</button>
    </form>
  </div>
</div>

<script>
  function openModal() {
    document.getElementById('restModal').style.display = 'flex';
  }
  function closeModal() {
    document.getElementById('restModal').style.display = 'none';
  }

  async function toggleApproval(id, approveState) {
    try {
      const res = await fetch(`/api/v1/admin/restaurants/${id}/approve`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ isApproved: approveState })
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert('Failed to update approval.');
      }
    } catch (err) {
      alert('Error connecting.');
    }
  }

  document.getElementById('create-rest-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;

    const payload = {
      name: document.getElementById('name').value.trim(),
      owner: document.getElementById('owner').value,
      cuisineType: document.getElementById('cuisineType').value,
      address: document.getElementById('address').value.trim(),
      deliveryTimeMinutes: document.getElementById('deliveryTimeMinutes').value,
      minOrderAmount: document.getElementById('minOrderAmount').value
    };

    try {
      const res = await fetch('/api/v1/admin/restaurants', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Restaurant registered successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Error registering restaurant.');
        btn.disabled = false;
      }
    } catch (err) {
      alert('Server error.');
      btn.disabled = false;
    }
  });
</script>

<%- include('partials/admin-footer') %>
