<%- include('partials/header') %>

<div style="margin-bottom: 2rem;">
  <h2 style="font-weight: 800; font-size: 2rem;">Checkout</h2>
  <p class="text-muted">Choose your delivery address and payment option.</p>
</div>

<div class="grid-2">
  <!-- Address Selection and Payment Method -->
  <div>
    <!-- Addresses Card -->
    <div class="glass-card" style="margin-bottom: 2rem;">
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
        <h3 style="font-size:1.25rem; font-weight:800;"><i class="fa-solid fa-location-dot" style="color:var(--accent-color);"></i> Delivery Address</h3>
        <a href="/addresses" class="btn btn-secondary btn-sm"><i class="fa-solid fa-plus"></i> Add New</a>
      </div>

      <div id="address-list" style="display:flex; flex-direction:column; gap:1rem;">
        <% if (addresses && addresses.length > 0) { %>
          <% addresses.forEach(addr => { %>
            <label class="address-card <%= addr.isDefault ? 'default' : '' %>" style="display:flex; align-items:center; justify-content:space-between; cursor:pointer;">
              <div style="display:flex; gap:1rem; align-items:center;">
                <input type="radio" name="addressId" value="<%= addr._id %>" <%= addr.isDefault ? 'checked' : '' %>>
                <div>
                  <strong style="color:white;"><%= addr.label %></strong>
                  <p class="text-muted" style="font-size:0.85rem; margin-top:0.25rem;"><%= addr.addressLine1 %>, <%= addr.city %>, <%= addr.state %> - <%= addr.postalCode %></p>
                </div>
              </div>
            </label>
          <% }) %>
        <% } else { %>
          <div style="text-align:center; padding:1.5rem;">
            <p class="text-muted" style="margin-bottom:1rem;">No addresses found in your account.</p>
            <a href="/addresses" class="btn btn-primary btn-sm">Add Address now</a>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Payment Methods -->
    <div class="glass-card">
      <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.5rem;"><i class="fa-solid fa-credit-card" style="color:var(--accent-color);"></i> Payment Method</h3>
      
      <div style="display:flex; flex-direction:column; gap:1rem;">
        <label class="address-card" style="cursor:pointer; display:flex; align-items:center; gap:1rem;">
          <input type="radio" name="paymentMethod" value="cod" checked>
          <div>
            <strong style="color:white;"><i class="fa-solid fa-hand-holding-dollar"></i> Cash on Delivery (COD)</strong>
            <p class="text-muted" style="font-size:0.8rem;">Pay cash when order is delivered.</p>
          </div>
        </label>
        
        <label class="address-card" style="cursor:pointer; display:flex; align-items:center; gap:1rem;">
          <input type="radio" name="paymentMethod" value="wallet">
          <div>
            <strong style="color:white;"><i class="fa-solid fa-wallet"></i> FoodClone Wallet</strong>
            <p class="text-muted" style="font-size:0.8rem;">Pay instantly from preloaded wallet credits.</p>
          </div>
        </label>
      </div>
    </div>
  </div>

  <!-- Billing checkout side card -->
  <div>
    <div class="glass-card">
      <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.5rem;">Bill Details</h3>

      <% 
         let subtotal = 0;
         cart.items.forEach(item => {
           if (item.food) subtotal += item.price;
         });
         let deliveryCharge = subtotal > 300 ? 0 : 40;
         let taxes = parseFloat((subtotal * 0.05).toFixed(2));
         let grandTotal = subtotal + deliveryCharge + taxes;
      %>

      <div style="display:flex; flex-direction:column; gap:0.75rem; font-size:0.95rem; margin-bottom:1.5rem; border-bottom:1px solid var(--border-color); padding-bottom:1rem;">
        <% cart.items.forEach(item => { %>
          <% if (item.food) { %>
            <div style="display:flex; justify-content:space-between;">
              <span class="text-muted"><%= item.food.name %> (x<%= item.quantity %>)</span>
              <span>₹<%= item.price %></span>
            </div>
          <% } %>
        <% }) %>
      </div>

      <div style="display:flex; flex-direction:column; gap:0.75rem; font-size:0.95rem; margin-bottom:1.5rem;">
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted">Subtotal</span>
          <span>₹<%= subtotal %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted">Delivery Speed Fees</span>
          <span><%= deliveryCharge === 0 ? 'FREE' : '₹' + deliveryCharge %></span>
        </div>
        <div style="display:flex; justify-content:space-between;">
          <span class="text-muted">Taxes & GST (5%)</span>
          <span>₹<%= taxes %></span>
        </div>
        <hr style="border-color: var(--border-color); margin: 0.5rem 0;">
        <div style="display:flex; justify-content:space-between; font-weight:800; font-size:1.15rem; margin-bottom: 1.5rem;">
          <span>Total Payable</span>
          <span class="price">₹<%= grandTotal %></span>
        </div>
      </div>

      <button id="placeOrderBtn" class="btn btn-primary w-100" onclick="placeOrder()">Place Order</button>
    </div>
  </div>
</div>

<script>
  async function placeOrder() {
    const addressRadio = document.querySelector('input[name="addressId"]:checked');
    if (!addressRadio) {
      alert('Please select or add a delivery address first.');
      return;
    }
    const addressId = addressRadio.value;
    const paymentMethod = document.querySelector('input[name="paymentMethod"]:checked').value;
    
    const btn = document.getElementById('placeOrderBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing Order...';

    try {
      const res = await fetch('/api/v1/orders', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ addressId, paymentMethod })
      });
      const json = await res.json();
      if (json.success) {
        window.location.href = `/orders/success/${json.orderId}`;
      } else {
        alert(json.message || 'Could not place order.');
        btn.disabled = false;
        btn.innerHTML = 'Place Order';
      }
    } catch (err) {
      alert('Server error. Try again.');
      btn.disabled = false;
      btn.innerHTML = 'Place Order';
    }
  }
</script>

<%- include('partials/footer') %>
