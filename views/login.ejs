<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %> - Food Platform
  </title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
  <main>
    <div class="glass-card">
      <div style="margin-bottom: 1.5rem;">
        <i class="fa-solid fa-utensils" style="color:var(--accent-color); font-size:2.5rem; margin-bottom: 0.5rem;"></i>
        <h2>Sign In</h2>
        <p class="text-muted">Access your account to order food or manage operations.</p>
      </div>

      <div id="alert" class="auth-alert-message"></div>

      <form id="login-form">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input id="email" type="email" class="form-input" placeholder="name@example.com" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="password-wrapper" style="width: 100%;">
            <input id="password" type="password" class="form-input" placeholder="••••••••" required>
            <button type="button" class="password-toggle-btn" onclick="togglePassword()"><i
                class="fa-solid fa-eye"></i></button>
          </div>
        </div>

        <button id="submitBtn" class="btn btn-primary" type="submit">Sign In</button>
      </form>

      <div class="auth-links">
        <a href="/register">Create an account</a>
        <a href="/forgot-password">Forgot password?</a>
      </div>

      <div
        style="margin-top: 1.5rem; border-top: 1px solid var(--border-color); padding-top: 1rem; display: flex; justify-content: space-around; font-size: 0.8rem;">
        <a href="/admin/login" style="color: #60a5fa; text-decoration: none;"><i class="fa-solid fa-user-shield"></i>
          Admin Portal</a>
        <a href="/owner/login" style="color: #ffb83d; text-decoration: none;"><i class="fa-solid fa-store"></i> Owner
          Portal</a>
        <a href="/delivery/login" style="color: #34d399; text-decoration: none;"><i class="fa-solid fa-motorcycle"></i>
          Rider Portal</a>
      </div>
    </div>
  </main>

  <script>
    function togglePassword() {
      const p = document.getElementById('password');
      p.type = p.type === 'password' ? 'text' : 'password';
    }

    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Signing in...';

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });
        const json = await res.json();
        if (json.success) {
          if (json.role === 'admin') {
            window.location.href = '/admin/dashboard';
          } else if (json.role === 'restaurant_owner') {
            window.location.href = '/owner/dashboard';
          } else if (json.role === 'delivery_boy') {
            window.location.href = '/delivery/dashboard';
          } else {
            window.location.href = '/';
          }
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Invalid credentials';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Sign In';
      }
    });
  </script>
</body>

</html>