<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - FoodClone</title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <main style="display:flex;align-items:center;justify-content:center;height:100vh;padding:1rem;">
    <div class="glass-card" style="max-width:420px;width:100%;padding:2rem;">
      <h2 style="margin-bottom:0.5rem;">Sign In</h2>
      <p class="text-muted" style="margin-bottom:1rem;">Access your account to order food or manage your restaurant.</p>

      <div id="alert" class="auth-alert-message" style="display:none;margin-bottom:0.75rem;"></div>

      <form id="login-form">
        <div class="form-group">
          <label for="email">Email</label>
          <input id="email" type="email" class="form-input" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="password-wrapper">
            <input id="password" type="password" class="form-input" required>
            <button type="button" class="password-toggle-btn" onclick="togglePassword()"><i class="fa-solid fa-eye"></i></button>
          </div>
        </div>

        <button id="submitBtn" class="btn btn-primary w-100" type="submit">Sign In</button>
      </form>

      <div style="margin-top:1rem;display:flex;justify-content:space-between;align-items:center;font-size:0.9rem;">
        <a href="/register">Create an account</a>
        <a href="/reset-password">Forgot password?</a>
      </div>
    </div>
  </main>

  <script>
    function togglePassword() {
      const p = document.getElementById('password');
      p.type = p.type === 'password' ? 'text' : 'password';
    }

    document.getElementById('login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Signing in...';

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });
        const json = await res.json();
        if (json.success) {
          window.location.href = '/';
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Invalid credentials';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Sign In';
      }
    });
  </script>
</body>
</html>
