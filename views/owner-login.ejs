<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - FoodClone</title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body style="background-image: radial-gradient(circle at 10% 20%, rgba(255, 165, 2, 0.05) 0%, transparent 40%);">
  <main>
    <div class="glass-card" style="border-color: rgba(255, 165, 2, 0.25);">
      <div style="margin-bottom: 1.5rem;">
        <i class="fa-solid fa-store" style="color:#ffa502; font-size:3rem; margin-bottom: 0.5rem;"></i>
        <h2>Partner Portal</h2>
        <p class="text-muted">Sign in to manage your kitchen menu and track orders.</p>
      </div>

      <div id="alert" class="auth-alert-message"></div>

      <form id="owner-login-form">
        <div class="form-group">
          <label for="email">Partner Email Address</label>
          <input id="email" type="email" class="form-input" placeholder="kitchen@example.com" required>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <input id="password" type="password" class="form-input" placeholder="••••••••" required>
        </div>

        <button id="submitBtn" class="btn btn-primary" style="background-color:#ffa502;" type="submit">Access Dashboard</button>
      </form>

      <div class="auth-links" style="justify-content: center;">
        <a href="/login">&larr; Back to customer login</a>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('owner-login-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const email = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value;
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Authenticating...';

      try {
        const res = await fetch('/api/v1/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, password })
        });
        const json = await res.json();
        if (json.success) {
          if (json.role === 'restaurant_owner') {
            window.location.href = '/owner/dashboard';
          } else {
            alertDiv.className = 'auth-alert-message error';
            alertDiv.innerText = 'Access Denied: Account role mismatch.';
            alertDiv.style.display = 'block';
            btn.disabled = false;
            btn.innerHTML = 'Access Dashboard';
          }
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Invalid credentials';
          alertDiv.style.display = 'block';
          btn.disabled = false;
          btn.innerHTML = 'Access Dashboard';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = 'Access Dashboard';
      }
    });
  </script>
</body>
</html>
