<%- include('partials/header') %>

<div class="glass-card" style="margin-bottom:2.5rem; padding: 2rem;">
  <div style="display:flex; gap:2.5rem; flex-wrap:wrap; align-items:center;">
    <% if (food.image) { %>
      <div style="flex:1; min-width:300px;">
        <img src="<%= food.image %>" style="width:100%; max-height:350px; object-fit:cover; border-radius:20px;" alt="<%= food.name %>">
      </div>
    <% } %>
    
    <div style="flex:1.5; min-width:300px; display:flex; flex-direction:column; gap:1.25rem;">
      <div>
        <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.5rem;">
          <h2 style="font-size:2.25rem; font-weight:800;"><%= food.name %></h2>
          <% if (food.isVeg) { %>
            <span style="color:#10b981; font-size:0.9rem;"><i class="fa-solid fa-circle"></i> Veg</span>
          <% } else { %>
            <span style="color:#ef4444; font-size:0.9rem;"><i class="fa-solid fa-circle"></i> Non-Veg</span>
          <% } %>
        </div>
        <p class="text-muted"><%= food.category ? food.category.name : 'Food item' %> &bull; <a href="/restaurants/<%= food.restaurant._id %>" style="color:var(--accent-color); text-decoration:none;"><%= food.restaurant.name %></a></p>
      </div>

      <p style="font-size:1rem; line-height:1.6; color:#cbd5e1;"><%= food.description %></p>

      <div style="display:flex; align-items:center; gap:1.5rem;">
        <span class="price" style="font-size:1.8rem;">₹<%= food.price %></span>
        <% if (food.isAvailable) { %>
          <button class="btn btn-primary" onclick="addToCart('<%= food._id %>')" style="width:auto;"><i class="fa-solid fa-cart-plus"></i> Add to Cart</button>
        <% } else { %>
          <button class="btn btn-secondary" style="width:auto;" disabled>Out of stock</button>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Ratings & Reviews Section -->
<div class="grid-2">
  <div>
    <h3 style="font-size:1.4rem; font-weight:800; margin-bottom:1.5rem;">Customer Ratings & Reviews</h3>
    
    <div style="display:flex; flex-direction:column; gap:1rem;">
      <% if (ratings && ratings.length > 0) { %>
        <% ratings.forEach(r => { %>
          <div class="glass-card" style="padding:1.25rem; border-radius:14px; background:rgba(255,255,255,0.01);">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
              <strong style="color:white;"><%= r.user ? r.user.name : 'Anonymous' %></strong>
              <span style="color:#ffa502; font-weight:700;"><i class="fa-solid fa-star"></i> <%= r.rating %>/5</span>
            </div>
            <p class="text-muted" style="font-size:0.875rem;"><%= r.comment || 'No review comments left.' %></p>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No ratings yet. Be the first to rate this food!</p>
      <% } %>
    </div>
  </div>

  <!-- Review Submission Box -->
  <div>
    <div class="glass-card">
      <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1rem;">Leave a Rating</h3>
      <form id="rating-form" style="display:flex; flex-direction:column; gap:1rem;">
        <input type="hidden" id="foodId" value="<%= food._id %>">
        <input type="hidden" id="restaurantId" value="<%= food.restaurant._id %>">

        <div class="form-group">
          <label for="rating">Rating (1 to 5 stars)</label>
          <select id="rating" class="form-input" required>
            <option value="5">⭐⭐⭐⭐⭐ 5 Stars</option>
            <option value="4">⭐⭐⭐⭐ 4 Stars</option>
            <option value="3">⭐⭐⭐ 3 Stars</option>
            <option value="2">⭐⭐ 2 Stars</option>
            <option value="1">⭐ 1 Star</option>
          </select>
        </div>

        <div class="form-group">
          <label for="comment">Review Comment</label>
          <textarea id="comment" class="form-input" style="height:80px; resize:none;" placeholder="Write your review here..."></textarea>
        </div>

        <button type="submit" class="btn btn-primary">Submit Review</button>
      </form>
    </div>
  </div>
</div>

<script>
  async function addToCart(foodId) {
    try {
      const res = await fetch('/api/v1/cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ foodId, quantity: 1 })
      });
      const json = await res.json();
      if (json.success) {
        alert('Food added to cart successfully!');
      } else {
        alert(json.message || 'Could not add to cart.');
      }
    } catch (err) {
      alert('Error connecting to server. Try again.');
    }
  }

  document.getElementById('rating-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const foodId = document.getElementById('foodId').value;
    const restaurantId = document.getElementById('restaurantId').value;
    const rating = document.getElementById('rating').value;
    const comment = document.getElementById('comment').value;

    try {
      const res = await fetch('/api/v1/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ foodId, restaurantId, rating, comment })
      });
      const json = await res.json();
      if (json.success) {
        alert('Rating submitted successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Failed to submit review.');
      }
    } catch (err) {
      alert('Server error. Try again.');
    }
  });
</script>

<%- include('partials/footer') %>
