<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Food Platform – Order Delicious Food Delivered Fast</title>
  <meta name="description" content="Food Platform connects you with the best local restaurants. Order food online and get it delivered to your door in minutes.">
  <link rel="stylesheet" href="/css/landing.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

  <!-- ── NAVBAR ── -->
  <nav class="navbar">
    <a href="/" class="navbar-brand">
      <i class="fa-solid fa-utensils"></i>
      <span>Food Platform</span>
    </a>

    <ul class="navbar-links">
      <li><a href="#features">Features</a></li>
      <li><a href="#how-it-works">How It Works</a></li>
      <li><a href="#portals">Portals</a></li>
    </ul>

    <div class="navbar-actions">
      <a href="/login" class="btn btn-outline">Sign In</a>
      <a href="/register" class="btn btn-primary">
        <i class="fa-solid fa-arrow-right"></i> Get Started
      </a>
    </div>
  </nav>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-bg"></div>

    <div class="hero-grid">
      <!-- Left: Copy -->
      <div class="hero-content">
        <div class="hero-badge">
          <i class="fa-solid fa-bolt"></i> Fast Delivery • Great Food
        </div>

        <h1 class="hero-title">
          Crave It.<br>
          Order It.<br>
          <span class="gradient-text">Love It.</span>
        </h1>

        <p class="hero-desc">
          Discover restaurants around you, browse hundreds of delicious dishes, and get them delivered to your door — hot, fresh and on time. Every single time.
        </p>

        <div class="hero-ctas">
          <a href="/register" class="btn btn-primary btn-lg">
            <i class="fa-solid fa-utensils"></i> Order Now
          </a>
          <a href="/login" class="btn btn-outline btn-lg">
            <i class="fa-solid fa-right-to-bracket"></i> Sign In
          </a>
        </div>

        <div class="hero-stats">
          <div class="hero-stat">
            <div class="stat-num">500+</div>
            <div class="stat-label">Restaurants</div>
          </div>
          <div class="hero-stat">
            <div class="stat-num">30 min</div>
            <div class="stat-label">Avg. Delivery</div>
          </div>
          <div class="hero-stat">
            <div class="stat-num">50k+</div>
            <div class="stat-label">Happy Customers</div>
          </div>
        </div>
      </div>

      <!-- Right: Phone Mockup -->
      <div class="hero-visual">
        <!-- Floating badges -->
        <div class="float-badge top-left">
          <i class="fa-solid fa-star" style="color:#f59e0b;"></i> 4.9 Rated App
        </div>
        <div class="float-badge bottom-left">
          <i class="fa-solid fa-circle-check" style="color:#10b981;"></i> Order Confirmed!
        </div>
        <div class="float-badge bottom-right">
          <i class="fa-solid fa-motorcycle" style="color:#3b82f6;"></i> On the way · 12 min
        </div>

        <!-- Phone UI Mockup -->
        <div class="hero-phone-mockup">
          <div class="phone-notch"></div>
          <div class="phone-screen">
            <div class="phone-header">
              <span class="app-name">Food Platform</span>
              <i class="fa-solid fa-utensils"></i>
            </div>

            <div class="phone-search">
              <i class="fa-solid fa-magnifying-glass"></i>
              Search restaurants or dishes…
            </div>

            <div class="cat-row">
              <div class="cat-chip active">🍕 Pizza</div>
              <div class="cat-chip">🍔 Burgers</div>
              <div class="cat-chip">🍜 Noodles</div>
            </div>

            <div style="font-size:0.65rem; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.5px; margin-top:0.25rem;">
              Popular Near You
            </div>

            <div class="phone-card">
              <div class="phone-card-img">🍕</div>
              <div class="phone-card-info">
                <div class="phone-card-name">Margherita Classic</div>
                <div class="phone-card-meta">⭐ 4.8 · 20 min</div>
              </div>
              <div class="phone-card-price">₹249</div>
            </div>

            <div class="phone-card">
              <div class="phone-card-img">🍔</div>
              <div class="phone-card-info">
                <div class="phone-card-name">Smoky BBQ Burger</div>
                <div class="phone-card-meta">⭐ 4.7 · 25 min</div>
              </div>
              <div class="phone-card-price">₹199</div>
            </div>

            <div class="phone-card">
              <div class="phone-card-img">🍜</div>
              <div class="phone-card-info">
                <div class="phone-card-name">Wok Tossed Noodles</div>
                <div class="phone-card-meta">⭐ 4.6 · 18 min</div>
              </div>
              <div class="phone-card-price">₹179</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURES ── -->
  <section class="section" id="features">
    <div class="section-header">
      <div class="section-tag">Why Food Platform</div>
      <h2 class="section-title">Everything You Need in One App</h2>
      <p class="section-desc">From browsing menus to real-time tracking — we've built every feature to make ordering food as simple and enjoyable as possible.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon icon-red">
          <i class="fa-solid fa-bolt"></i>
        </div>
        <h3>Lightning-Fast Delivery</h3>
        <p>Our optimized delivery network ensures your food arrives hot and on time, every order, every day.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-blue">
          <i class="fa-solid fa-map-location-dot"></i>
        </div>
        <h3>Real-Time Tracking</h3>
        <p>Watch your order move from the kitchen to your door with live GPS tracking of your delivery rider.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-green">
          <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h3>Secure Payments</h3>
        <p>Pay via Cash on Delivery or your Food Platform Wallet — all transactions are protected and encrypted.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-yellow">
          <i class="fa-solid fa-star"></i>
        </div>
        <h3>Ratings & Reviews</h3>
        <p>Read honest reviews from real customers and make informed choices every time you order.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-purple">
          <i class="fa-solid fa-heart"></i>
        </div>
        <h3>Wishlist Favourites</h3>
        <p>Save your favourite restaurants and dishes to a personal wishlist for quick and easy reordering.</p>
      </div>

      <div class="feature-card">
        <div class="feature-icon icon-pink">
          <i class="fa-solid fa-clock-rotate-left"></i>
        </div>
        <h3>Order History</h3>
        <p>Access your complete order history and reorder your favourite meals with a single tap.</p>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ── -->
  <section class="section" id="how-it-works" style="background: rgba(255,255,255,0.01);">
    <div class="section-header">
      <div class="section-tag">Simple Process</div>
      <h2 class="section-title">Order in 4 Easy Steps</h2>
      <p class="section-desc">Getting your favourite food delivered has never been easier. Just follow these simple steps.</p>
    </div>

    <div class="steps-grid">
      <div class="step-card">
        <div class="step-num">1</div>
        <h3>Create Account</h3>
        <p>Sign up in seconds and set up your delivery addresses for a faster checkout every time.</p>
      </div>

      <div class="step-card">
        <div class="step-num">2</div>
        <h3>Browse Restaurants</h3>
        <p>Explore hundreds of local restaurants, filter by cuisine, and find exactly what you're craving.</p>
      </div>

      <div class="step-card">
        <div class="step-num">3</div>
        <h3>Add to Cart</h3>
        <p>Pick your dishes, customise your order, and head to a smooth, secure checkout.</p>
      </div>

      <div class="step-card">
        <div class="step-num">4</div>
        <h3>Enjoy Delivery</h3>
        <p>Track your order live and enjoy fresh, delicious food delivered straight to your door.</p>
      </div>
    </div>
  </section>

  <!-- ── PORTALS ── -->
  <section class="section" id="portals">
    <div class="section-header">
      <div class="section-tag">For Everyone</div>
      <h2 class="section-title">Dedicated Portals for Every Role</h2>
      <p class="section-desc">Food Platform isn't just for customers — it's a complete ecosystem for restaurants, delivery riders, and administrators.</p>
    </div>

    <div class="roles-grid">
      <a href="/register" class="role-card role-customer">
        <div class="role-icon">🛍️</div>
        <h3>Customer</h3>
        <p>Browse restaurants, manage your cart, track orders and enjoy great food delivered fast.</p>
        <span class="role-link" style="color:var(--accent-color);">
          Start Ordering <i class="fa-solid fa-arrow-right"></i>
        </span>
      </a>

      <a href="/owner/login" class="role-card role-owner">
        <div class="role-icon">🏪</div>
        <h3>Restaurant Owner</h3>
        <p>Manage your menu, track incoming orders, view sales analytics and grow your business.</p>
        <span class="role-link" style="color:var(--yellow-accent);">
          Owner Portal <i class="fa-solid fa-arrow-right"></i>
        </span>
      </a>

      <a href="/delivery/login" class="role-card role-rider">
        <div class="role-icon">🏍️</div>
        <h3>Delivery Rider</h3>
        <p>Accept delivery assignments, navigate with ease, and manage your earnings on the go.</p>
        <span class="role-link" style="color:var(--green-accent);">
          Rider Portal <i class="fa-solid fa-arrow-right"></i>
        </span>
      </a>

      <a href="/admin/login" class="role-card role-admin">
        <div class="role-icon">🛡️</div>
        <h3>Administrator</h3>
        <p>Full platform control — approve restaurants, manage users, configure settings and monitor activity.</p>
        <span class="role-link" style="color:var(--blue-accent);">
          Admin Portal <i class="fa-solid fa-arrow-right"></i>
        </span>
      </a>
    </div>
  </section>

  <!-- ── CTA ── -->
  <section class="cta-section">
    <div class="cta-inner">
      <h2>Ready to Order? <span style="color:var(--accent-color);">Let's Go 🚀</span></h2>
      <p>Join thousands of happy customers who order delicious food through Food Platform every day. Create your free account and start ordering in minutes.</p>
      <div class="cta-buttons">
        <a href="/register" class="btn btn-primary btn-lg">
          <i class="fa-solid fa-user-plus"></i> Create Free Account
        </a>
        <a href="/login" class="btn btn-outline btn-lg">
          <i class="fa-solid fa-right-to-bracket"></i> Sign In
        </a>
      </div>
    </div>
  </section>

  <!-- ── FOOTER ── -->
  <footer class="landing-footer">
    <p>© 2026 <strong>Food Platform</strong>. All rights reserved.</p>

    <div class="footer-links">
      <a href="/login">Sign In</a>
      <a href="/register">Register</a>
      <a href="/owner/login">Restaurant</a>
      <a href="/delivery/login">Rider</a>
      <a href="/admin/login">Admin</a>
    </div>
  </footer>

</body>
</html>
