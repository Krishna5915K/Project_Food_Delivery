<%- include('partials/delivery-header') %>

<div style="margin-bottom: 2rem;">
  <h2 style="font-weight: 800; font-size: 1.75rem;">Assigned Runs</h2>
  <p class="text-muted">Active deliveries assigned to you for pick-up and drop-off.</p>
</div>

<div style="display:flex; flex-direction:column; gap:1rem;">
  <% if (orders && orders.length > 0) { %>
    <% orders.forEach(o => { %>
      <div class="order-card">
        <div class="order-title">
          <span>Order #<%= o._id.toString().slice(-6).toUpperCase() %></span>
          <span style="font-weight:700; color:var(--accent-color);">₹<%= o.totalAmount %></span>
        </div>
        
        <div style="font-size:0.9rem; color:var(--text-secondary); display:flex; flex-direction:column; gap:0.5rem; margin:0.25rem 0;">
          <div><i class="fa-solid fa-store"></i> Restaurant: <strong style="color:white;"><%= o.restaurant ? o.restaurant.name : 'Unknown' %></strong></div>
          <div><i class="fa-solid fa-location-dot"></i> Delivery Address: <span style="color:white;"><%= o.deliveryAddress %></span></div>
          <div><i class="fa-solid fa-clock"></i> Status: <span style="color:var(--accent-color); font-weight:700; text-transform:uppercase;"><%= o.orderStatus.replace('_', ' ') %></span></div>
        </div>

        <div style="border-top:1px solid var(--border-color); padding-top:0.75rem; display:flex; gap:0.5rem; margin-top:0.5rem;">
          <% if (o.orderStatus === 'confirmed' || o.orderStatus === 'preparing') { %>
            <button class="btn btn-primary" onclick="updateStatus('<%= o._id %>', 'picked_up')"><i class="fa-solid fa-box"></i> Mark Picked Up</button>
          <% } else if (o.orderStatus === 'picked_up') { %>
            <button class="btn btn-primary" style="background-color:#3b82f6;" onclick="updateStatus('<%= o._id %>', 'on_the_way')"><i class="fa-solid fa-road"></i> Mark On The Way</button>
          <% } else if (o.orderStatus === 'on_the_way') { %>
            <button class="btn btn-primary" style="background-color:#10b981;" onclick="updateStatus('<%= o._id %>', 'delivered')"><i class="fa-solid fa-check"></i> Mark Delivered</button>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="glass-card" style="text-align:center; padding:3rem;">
      <i class="fa-solid fa-truck-fast" style="font-size:3rem; color:var(--text-secondary); margin-bottom:1rem;"></i>
      <h3>No Active Runs</h3>
      <p class="text-muted" style="margin-top:0.5rem;">You do not have any active runs assigned. Check the main console to stay online.</p>
    </div>
  <% } %>
</div>

<script>
  async function updateStatus(orderId, newStatus) {
    try {
      const res = await fetch(`/api/v1/delivery/orders/${orderId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus })
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert(json.message || 'Error updating status.');
      }
    } catch (err) {
      alert('Network error.');
    }
  }
</script>

<%- include('partials/delivery-footer') %>
