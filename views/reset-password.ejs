<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - FoodClone</title>
  <link rel="stylesheet" href="/css/auth.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
  <main>
    <div class="glass-card">
      <div style="margin-bottom: 1.5rem;">
        <i class="fa-solid fa-lock-open" style="color:var(--accent-color); font-size:2.5rem; margin-bottom: 0.5rem;"></i>
        <h2>Reset Password</h2>
        <p class="text-muted">Enter a new secure password for your account.</p>
      </div>

      <div id="alert" class="auth-alert-message"></div>

      <form id="reset-form">
        <input type="hidden" id="token" value="<%= token %>">
        
        <div class="form-group">
          <label for="password">New Password</label>
          <input id="password" type="password" class="form-input" placeholder="Min. 6 characters" minlength="6" required>
        </div>
        
        <div class="form-group">
          <label for="confirm-password">Confirm Password</label>
          <input id="confirm-password" type="password" class="form-input" placeholder="Re-enter password" minlength="6" required>
        </div>

        <button id="submitBtn" class="btn btn-primary" type="submit">Update Password</button>
      </form>

      <div class="auth-links" style="justify-content: center; gap: 0.5rem;">
        <a href="/login" style="font-weight: 700;">Back to Login</a>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const alertDiv = document.getElementById('alert');
      alertDiv.style.display = 'none';

      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirm-password').value;
      const token = document.getElementById('token').value;

      if (password !== confirmPassword) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Passwords do not match.';
        alertDiv.style.display = 'block';
        return;
      }

      if (!token) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Reset token is missing. Please check your link.';
        alertDiv.style.display = 'block';
        return;
      }

      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Resetting...';

      try {
        const res = await fetch('/api/v1/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, password })
        });
        const json = await res.json();
        if (json.success) {
          alertDiv.className = 'auth-alert-message success';
          alertDiv.innerText = json.message || 'Password reset successful! Redirecting to login...';
          alertDiv.style.display = 'block';
          setTimeout(() => {
            window.location.href = '/login';
          }, 2000);
        } else {
          alertDiv.className = 'auth-alert-message error';
          alertDiv.innerText = json.message || 'Failed to reset password.';
          alertDiv.style.display = 'block';
        }
      } catch (err) {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = 'Server error. Try again.';
        alertDiv.style.display = 'block';
      } finally {
        btn.disabled = false;
        btn.innerHTML = 'Update Password';
      }
    });
  </script>
</body>
</html>
