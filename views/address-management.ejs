<%- include('partials/header') %>

<div style="margin-bottom: 2.5rem;">
  <h2 style="font-weight: 800; font-size: 2rem;">Address Management</h2>
  <p class="text-muted">Manage your saved addresses for faster deliveries at checkout.</p>
</div>

<div class="grid-2">
  <!-- Saved Addresses List -->
  <div>
    <h3 style="font-size:1.3rem; font-weight:800; margin-bottom:1.5rem;">Saved Addresses</h3>
    
    <div style="display:flex; flex-direction:column; gap:1rem;">
      <% if (addresses && addresses.length > 0) { %>
        <% addresses.forEach(addr => { %>
          <div class="address-card <%= addr.isDefault ? 'default' : '' %>">
            <div>
              <strong style="color:white; font-size:1.05rem;"><%= addr.label %></strong>
              <% if (addr.isDefault) { %>
                <span class="badge" style="background:var(--success-bg); color:var(--success-color); font-size:0.7rem; padding:0.15rem 0.4rem; border-radius:4px; margin-left:0.5rem;">Default</span>
              <% } %>
              <p class="text-muted" style="font-size:0.875rem; margin-top:0.25rem;"><%= addr.addressLine1 %>, <%= addr.addressLine2 ? addr.addressLine2 + ', ' : '' %><%= addr.city %>, <%= addr.state %> - <%= addr.postalCode %></p>
            </div>
            
            <button class="btn btn-secondary btn-sm" style="padding:0.4rem 0.6rem;" onclick="deleteAddress('<%= addr._id %>')">
              <i class="fa-solid fa-trash-can" style="color:#ef4444;"></i>
            </button>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-muted">No addresses saved. Add one using the form on the right.</p>
      <% } %>
    </div>
  </div>

  <!-- Add Address Form -->
  <div>
    <div class="glass-card">
      <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.25rem;">Add New Address</h3>
      <div id="alert" class="auth-alert-message"></div>

      <form id="address-form" style="display:flex; flex-direction:column; gap:1rem;">
        <div class="form-group">
          <label for="label">Address Label</label>
          <select id="label" class="form-input" required>
            <option value="Home">Home</option>
            <option value="Work">Work</option>
            <option value="Other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="addressLine1">Address Line 1</label>
          <input type="text" id="addressLine1" class="form-input" placeholder="Flat, House no., Building, Company" required>
        </div>

        <div class="form-group">
          <label for="addressLine2">Address Line 2 (Optional)</label>
          <input type="text" id="addressLine2" class="form-input" placeholder="Area, Street, Sector, Village">
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label for="city">City</label>
            <input type="text" id="city" class="form-input" placeholder="e.g. Bangalore" required>
          </div>
          <div class="form-group">
            <label for="state">State</label>
            <input type="text" id="state" class="form-input" placeholder="e.g. Karnataka" required>
          </div>
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
          <div class="form-group">
            <label for="postalCode">Pincode / Postal Code</label>
            <input type="text" id="postalCode" class="form-input" placeholder="e.g. 560001" required>
          </div>
          <div class="form-group">
            <label for="country">Country</label>
            <input type="text" id="country" class="form-input" value="India" required>
          </div>
        </div>

        <div class="form-group" style="flex-direction:row; align-items:center; gap:0.5rem; cursor:pointer;">
          <input type="checkbox" id="isDefault" style="width:16px; height:16px;">
          <label for="isDefault" style="cursor:pointer; margin-bottom:0;">Set as default address</label>
        </div>

        <button type="submit" id="submitBtn" class="btn btn-primary">Save Address</button>
      </form>
    </div>
  </div>
</div>

<script>
  async function deleteAddress(id) {
    if (!confirm('Are you sure you want to delete this address?')) return;
    try {
      const res = await fetch(`/api/v1/users/addresses/${id}`, {
        method: 'DELETE'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert(json.message || 'Failed to delete address.');
      }
    } catch (err) {
      alert('Server error.');
    }
  }

  document.getElementById('address-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const alertDiv = document.getElementById('alert');
    alertDiv.style.display = 'none';

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';

    const payload = {
      label: document.getElementById('label').value,
      addressLine1: document.getElementById('addressLine1').value.trim(),
      addressLine2: document.getElementById('addressLine2').value.trim(),
      city: document.getElementById('city').value.trim(),
      state: document.getElementById('state').value.trim(),
      postalCode: document.getElementById('postalCode').value.trim(),
      country: document.getElementById('country').value.trim(),
      isDefault: document.getElementById('isDefault').checked,
      latitude: 12.9716, // Simulated default coordinates
      longitude: 77.5946
    };

    try {
      const res = await fetch('/api/v1/users/addresses', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alertDiv.className = 'auth-alert-message success';
        alertDiv.innerText = 'Address saved successfully!';
        alertDiv.style.display = 'block';
        setTimeout(() => {
          window.location.reload();
        }, 1000);
      } else {
        alertDiv.className = 'auth-alert-message error';
        alertDiv.innerText = json.message || 'Failed to save address.';
        alertDiv.style.display = 'block';
        btn.disabled = false;
        btn.innerHTML = 'Save Address';
      }
    } catch (err) {
      alertDiv.className = 'auth-alert-message error';
      alertDiv.innerText = 'Server error. Try again.';
      alertDiv.style.display = 'block';
      btn.disabled = false;
      btn.innerHTML = 'Save Address';
    }
  });
</script>

<%- include('partials/footer') %>
