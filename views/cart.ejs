<%- include('partials/header') %>

<div style="margin-bottom: 2rem;">
  <h2 style="font-weight: 800; font-size: 2rem;">Shopping Cart</h2>
  <p class="text-muted">Review your selected meals before finalizing your order.</p>
</div>

<div class="grid-2">
  <!-- Cart items list -->
  <div>
    <% if (cart && cart.items && cart.items.length > 0) { %>
      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
        <span style="font-weight:600;"><i class="fa-solid fa-store" style="color:var(--accent-color);"></i> Ordering from: <%= cart.restaurant ? cart.restaurant.name : 'Restaurant' %></span>
        <button class="btn btn-secondary btn-sm" onclick="clearCart()"><i class="fa-solid fa-trash-can"></i> Clear Cart</button>
      </div>

      <div class="cart-list">
        <% cart.items.forEach(item => { %>
          <% if (item.food) { %>
            <div class="cart-item">
              <div style="display:flex; gap:1rem; align-items:center;">
                <% if (item.food.image) { %>
                  <img src="<%= item.food.image %>" style="width:60px; height:60px; object-fit:cover; border-radius:8px;" alt="<%= item.food.name %>">
                <% } %>
                <div>
                  <h4 style="font-size:1rem; color:white; font-weight:700;"><%= item.food.name %></h4>
                  <span class="text-muted" style="font-size:0.8rem;">₹<%= item.food.price %> each</span>
                </div>
              </div>

              <div style="display:flex; align-items:center; gap:2rem;">
                <div class="quantity-controls">
                  <button class="qty-btn" onclick="updateQty('<%= item._id %>', <%= item.quantity - 1 %>)">-</button>
                  <span style="font-weight:700; width:20px; text-align:center;"><%= item.quantity %></span>
                  <button class="qty-btn" onclick="updateQty('<%= item._id %>', <%= item.quantity + 1 %>)">+</button>
                </div>

                <strong class="price">₹<%= item.price %></strong>

                <button class="btn btn-secondary btn-sm" style="padding:0.35rem 0.5rem;" onclick="removeItem('<%= item._id %>')">
                  <i class="fa-solid fa-xmark"></i>
                </button>
              </div>
            </div>
          <% } %>
        <% }) %>
      </div>
    <% } else { %>
      <div class="glass-card" style="text-align:center; padding:3rem;">
        <i class="fa-solid fa-basket-shopping" style="font-size:3rem; color:var(--text-secondary); margin-bottom:1rem;"></i>
        <h3>Your Cart is Empty</h3>
        <p class="text-muted" style="margin: 0.5rem 0 1.5rem;">Looks like you haven't added anything to your cart yet.</p>
        <a href="/restaurants" class="btn btn-primary" style="display:inline-flex; width:auto;">Browse Restaurants</a>
      </div>
    <% } %>
  </div>

  <!-- Cart Order summary -->
  <div>
    <% if (cart && cart.items && cart.items.length > 0) { %>
      <div class="glass-card">
        <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.5rem;">Order Summary</h3>
        
        <% 
           let subtotal = 0;
           cart.items.forEach(item => {
             if (item.food) subtotal += item.price;
           });
           let deliveryCharge = subtotal > 300 ? 0 : 40;
           let taxes = parseFloat((subtotal * 0.05).toFixed(2));
           let grandTotal = subtotal + deliveryCharge + taxes;
        %>

        <div style="display:flex; flex-direction:column; gap:0.75rem; font-size:0.95rem; margin-bottom:1.5rem;">
          <div style="display:flex; justify-content:space-between;">
            <span class="text-muted">Subtotal</span>
            <span>₹<%= subtotal %></span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span class="text-muted">Delivery Charges</span>
            <span><%= deliveryCharge === 0 ? 'FREE' : '₹' + deliveryCharge %></span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span class="text-muted">Taxes & GST (5%)</span>
            <span>₹<%= taxes %></span>
          </div>
          <hr style="border-color: var(--border-color); margin: 0.5rem 0;">
          <div style="display:flex; justify-content:space-between; font-weight:800; font-size:1.15rem;">
            <span>Grand Total</span>
            <span class="price">₹<%= grandTotal %></span>
          </div>
        </div>

        <a href="/checkout" class="btn btn-primary w-100">Proceed to Checkout</a>
      </div>
    <% } %>
  </div>
</div>

<script>
  async function updateQty(cartItemId, newQty) {
    try {
      const res = await fetch(`/api/v1/cart/${cartItemId}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quantity: newQty })
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert(json.message || 'Error updating quantity.');
      }
    } catch (err) {
      alert('Network error. Try again.');
    }
  }

  async function removeItem(cartItemId) {
    try {
      const res = await fetch(`/api/v1/cart/${cartItemId}`, {
        method: 'DELETE'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert('Could not remove item.');
      }
    } catch (err) {
      alert('Network error. Try again.');
    }
  }

  async function clearCart() {
    if (!confirm('Are you sure you want to clear your cart?')) return;
    try {
      const res = await fetch('/api/v1/cart/clear', {
        method: 'POST'
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      }
    } catch (err) {
      alert('Network error.');
    }
  }
</script>

<%- include('partials/footer') %>
