<%- include('partials/admin-header') %>

<div style="margin-bottom: 2rem;">
  <p class="text-muted">Analyze sales performance, system revenues, and delivery statuses.</p>
</div>

<div class="grid-2">
  <div class="glass-card" style="padding:2rem;">
    <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.5rem;"><i class="fa-solid fa-calculator" style="color:var(--success-color);"></i> Business Metrics</h3>
    
    <div style="display:flex; flex-direction:column; gap:1.25rem;">
      <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--border-color); padding-bottom:0.75rem;">
        <span class="text-muted">Total Completed Deliveries</span>
        <strong style="color:white; font-size:1.1rem;"><%= report.totalOrders %></strong>
      </div>
      <div style="display:flex; justify-content:space-between; border-bottom:1px solid var(--border-color); padding-bottom:0.75rem;">
        <span class="text-muted">Total Gross Earnings</span>
        <strong style="color:var(--success-color); font-size:1.25rem;">₹<%= report.revenue %></strong>
      </div>
      <div style="display:flex; justify-content:space-between; padding-bottom:0.75rem;">
        <span class="text-muted">Estimated Tax Collection (5%)</span>
        <strong style="color:white; font-size:1.1rem;">₹<%= (report.revenue * 0.05).toFixed(2) %></strong>
      </div>
    </div>
  </div>

  <div class="glass-card" style="padding:2rem;">
    <h3 style="font-size:1.25rem; font-weight:800; margin-bottom:1.5rem;"><i class="fa-solid fa-chart-bar" style="color:var(--accent-color);"></i> Order Status Distribution</h3>
    
    <div style="display:flex; flex-direction:column; gap:1rem;">
      <% report.breakdown.forEach(b => { %>
        <div style="display:flex; justify-content:space-between; align-items:center;">
          <span style="text-transform:capitalize;" class="text-muted"><%= b._id.replace('_', ' ') %></span>
          <strong style="color:white;"><%= b.count %> orders</strong>
        </div>
        <div style="background:rgba(255,255,255,0.05); width:100%; height:8px; border-radius:4px; overflow:hidden;">
          <div style="background:var(--accent-color); width:<%= (b.count / (report.totalOrders || 1)) * 100 %>%; height:100%;"></div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/admin-footer') %>
