<%- include('partials/admin-header') %>

<!-- Stats Row -->
<div class="stats-grid">
  <div class="stat-card">
    <span class="stat-label">Total Users</span>
    <span class="stat-val"><%= stats.userCount %></span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Approved Restaurants</span>
    <span class="stat-val" style="color:var(--warning-color);"><%= stats.restaurantCount %></span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Global Orders</span>
    <span class="stat-val" style="color:var(--accent-color);"><%= stats.orderCount %></span>
  </div>
  <div class="stat-card">
    <span class="stat-label">Net Sales Volume</span>
    <span class="stat-val" style="color:var(--success-color);">₹<%= stats.totalRevenue %></span>
  </div>
</div>

<!-- Recent Activities -->
<div class="table-card">
  <h3 style="font-size:1.2rem; font-weight:800; margin-bottom:1.25rem;"><i class="fa-solid fa-clock-rotate-left"></i> Recent Order Actions</h3>
  <table>
    <thead>
      <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Restaurant</th>
        <th>Amount</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (recentOrders && recentOrders.length > 0) { %>
        <% recentOrders.forEach(o => { %>
          <tr>
            <td><code>#<%= o._id.toString().slice(-6).toUpperCase() %></code></td>
            <td><%= o.user ? o.user.name : 'Guest' %></td>
            <td><%= o.restaurant ? o.restaurant.name : 'Unknown' %></td>
            <td style="font-weight:700;">₹<%= o.totalAmount %></td>
            <td>
              <span class="badge badge-info"><%= o.orderStatus.replace('_', ' ') %></span>
            </td>
            <td>
              <a href="/admin/orders" class="btn btn-secondary btn-sm" style="padding: 0.25rem 0.5rem;"><i class="fa-solid fa-eye"></i> View</a>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="6" style="text-align:center; color:var(--text-secondary);">No orders placed yet. Run seeder.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('partials/admin-footer') %>
