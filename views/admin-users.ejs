<%- include('partials/admin-header') %>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 2rem;">
  <div>
    <p class="text-muted">Display, filter, and modify system accounts or create administrative staff.</p>
  </div>
  <button class="btn btn-primary" onclick="openModal()"><i class="fa-solid fa-user-plus"></i> Create Staff User</button>
</div>

<div class="table-card">
  <table>
    <thead>
      <tr>
        <th>Full Name</th>
        <th>Email ID</th>
        <th>Phone</th>
        <th>Role</th>
        <th>Status</th>
        <th>Toggle Status</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr>
          <td><strong><%= u.name %></strong></td>
          <td><%= u.email %></td>
          <td><%= u.phone || 'N/A' %></td>
          <td>
            <span style="text-transform:capitalize; font-weight:600;"><%= u.role.replace('_', ' ') %></span>
          </td>
          <td>
            <span class="badge <%= u.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= u.status %></span>
          </td>
          <td>
            <% if (u.status === 'active') { %>
              <button class="btn btn-secondary btn-sm" onclick="toggleUserStatus('<%= u._id %>', 'inactive')" style="color:var(--danger-color);"><i class="fa-solid fa-ban"></i> Deactivate</button>
            <% } else { %>
              <button class="btn btn-secondary btn-sm" onclick="toggleUserStatus('<%= u._id %>', 'active')" style="color:var(--success-color);"><i class="fa-solid fa-circle-check"></i> Activate</button>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<!-- Add User Modal -->
<div id="userModal" class="modal">
  <div class="modal-content">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
      <h3 style="font-size:1.25rem; font-weight:800; color:white;">Create Staff Account</h3>
      <button onclick="closeModal()" style="background:transparent; border:none; color:white; cursor:pointer; font-size:1.2rem;"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <form id="create-user-form" style="display:flex; flex-direction:column; gap:1rem;">
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" class="form-input" required placeholder="John Doe">
      </div>
      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" class="form-input" required placeholder="staff@foodclone.com">
      </div>
      <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="tel" id="phone" class="form-input" required placeholder="+919876543210">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" class="form-input" required placeholder="••••••••" minlength="6">
      </div>
      <div class="form-group">
        <label for="role">Assign Role</label>
        <select id="role" class="form-select" onchange="toggleDeliveryFields()" required>
          <option value="admin">System Admin</option>
          <option value="restaurant_owner">Restaurant Owner</option>
          <option value="delivery_boy">Delivery Rider</option>
        </select>
      </div>

      <!-- Optional fields for delivery boy -->
      <div id="delivery-fields" style="display:none; flex-direction:column; gap:1rem; border-top:1px solid var(--border-color); padding-top:1rem;">
        <div class="form-group">
          <label for="vehicleType">Vehicle Type</label>
          <select id="vehicleType" class="form-select">
            <option value="bike">Motorbike</option>
            <option value="scooter">Scooter</option>
            <option value="bicycle">Bicycle</option>
          </select>
        </div>
        <div class="form-group">
          <label for="vehicleNumber">Vehicle Number</label>
          <input type="text" id="vehicleNumber" class="form-input" placeholder="KA-01-XX-XXXX">
        </div>
        <div class="form-group">
          <label for="licenseNumber">Driving License Number</label>
          <input type="text" id="licenseNumber" class="form-input" placeholder="DL-XXXXXXXXXXXXX">
        </div>
      </div>

      <button type="submit" id="submitBtn" class="btn btn-primary" style="margin-top:1rem;">Register Account</button>
    </form>
  </div>
</div>

<script>
  function openModal() {
    document.getElementById('userModal').style.display = 'flex';
  }
  function closeModal() {
    document.getElementById('userModal').style.display = 'none';
  }
  function toggleDeliveryFields() {
    const role = document.getElementById('role').value;
    const fields = document.getElementById('delivery-fields');
    if (role === 'delivery_boy') {
      fields.style.display = 'flex';
    } else {
      fields.style.display = 'none';
    }
  }

  async function toggleUserStatus(userId, newStatus) {
    if (!confirm(`Are you sure you want to set user to ${newStatus}?`)) return;
    try {
      const res = await fetch(`/api/v1/admin/users/${userId}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ status: newStatus })
      });
      const json = await res.json();
      if (json.success) {
        window.location.reload();
      } else {
        alert(json.message || 'Failed to update status.');
      }
    } catch (err) {
      alert('Network error.');
    }
  }

  document.getElementById('create-user-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Creating...';

    const payload = {
      name: document.getElementById('name').value.trim(),
      email: document.getElementById('email').value.trim(),
      phone: document.getElementById('phone').value.trim(),
      password: document.getElementById('password').value,
      role: document.getElementById('role').value,
      vehicleType: document.getElementById('vehicleType').value,
      vehicleNumber: document.getElementById('vehicleNumber').value.trim(),
      licenseNumber: document.getElementById('licenseNumber').value.trim()
    };

    try {
      const res = await fetch('/api/v1/admin/users', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });
      const json = await res.json();
      if (json.success) {
        alert('Staff account created successfully!');
        window.location.reload();
      } else {
        alert(json.message || 'Error creating account.');
        btn.disabled = false;
        btn.innerHTML = 'Register Account';
      }
    } catch (err) {
      alert('Server error.');
      btn.disabled = false;
      btn.innerHTML = 'Register Account';
    }
  });
</script>

<%- include('partials/admin-footer') %>
